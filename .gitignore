# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.suo
*.user

# OS
.DS_Store
Thumbs.db

# Game saves (future)
saves/

# Claude agent memory (local only)
.claude/

# ── Unity generated artifacts ─────────────────────────────────────────────────
# These directories are regenerated by the Unity Editor on open — never commit them.
UnityProject/Library/
UnityProject/Temp/
UnityProject/Obj/
UnityProject/Builds/
UnityProject/UserSettings/
UnityProject/Logs/
UnityProject/.vsconfig

# Unity auto-generated meta files for empty folders (safe to ignore)
# Individual *.meta files beside tracked assets ARE committed (Unity needs them)
UnityProject/[Rr]ecycleBin/

# Visual Studio / Rider generated solution files (regenerated by Unity)
UnityProject/*.sln
UnityProject/*.csproj
UnityProject/*.unityproj

# OS files inside the Unity project
UnityProject/**/.DS_Store
UnityProject/**/Thumbs.db
